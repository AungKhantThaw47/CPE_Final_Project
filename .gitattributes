# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for all text files (Unix-style)
*.py text eol=lf
*.js text eol=lf
*.sh text eol=lf
*.tf text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf

# Binary files - don't normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
