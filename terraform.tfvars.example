# Copy this file to terraform.tfvars and fill in your values
# Keep sensitive values in .env as TF_VAR_* entries instead of committing them here.
project_id  = "your-gcp-project-id"
region      = "us-central1"
zone        = "us-central1-a"
environment = "dev"
execution_environment = "EXECUTION_ENVIRONMENT_GEN2"
neo4j_uri   = "neo4j+s://your-instance.databases.neo4j.io"
neo4j_user  = "neo4j"
neo4j_password = "your-neo4j-password"
neo4j_database = "neo4j"
daily_notify_email = "alerts@example.com"
notify_webhook_url = "https://your-notification-endpoint.example/send-email"
