      "properties": {
        "name": "DVB Burmese News",
        "url": "https://dvb.no/category/8/news"
      }
    },
    {
      "key": "job:dvb-crawler-job",
      "label": "CloudRunJob",
      "properties": {
        "name": "dvb-crawler-job",
        "runtime": "Node.js",
        "cpu": "1",
        "memory": "512Mi",
        "trigger": "manual_or_workflow"
      }
    },
    {
      "key": "job:dvb-text-cleaner-job",
      "label": "CloudRunJob",
      "properties": {
        "name": "dvb-text-cleaner-job",
        "runtime": "Python",
        "cpu": "1",
        "memory": "512Mi",
        "trigger": "manual_or_workflow"
      }
    },
    {
      "key": "job:crisis-classifier-job",
      "label": "CloudRunJob",
      "properties": {
        "name": "crisis-classifier-job",
        "runtime": "Python + Hugging Face",
        "cpu": "4",
        "memory": "16Gi",
        "trigger": "manual_or_workflow"
      }
    },
    {
      "key": "job:gpu-batch-job",
      "label": "CloudRunJob",
      "properties": {
        "name": "gpu-batch-job",
        "runtime": "Python + PyTorch",
        "cpu": "4",
        "memory": "16Gi",
        "gpu": "nvidia-l4",
        "trigger": "manual"
      }
    },
    {
      "key": "job:daily-data-processor",
      "label": "CloudRunJob",
      "properties": {
        "name": "daily-data-processor",
        "runtime": "Python",
        "cpu": "1",
        "memory": "512Mi",
        "schedule": "0 * * * *"
      }
    },
    {
      "key": "service:mlflow",
      "label": "CloudRunService",
      "properties": {
        "name": "mlflow",
        "runtime": "MLflow",
        "cpu": "2",
        "memory": "4Gi",
        "min_instances": 0,
        "max_instances": 2
      }
    },
    {
      "key": "service:crisis-admin",
      "label": "CloudRunService",
      "properties": {
        "name": "crisis-admin",
