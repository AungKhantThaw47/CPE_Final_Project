        "cpu": "1",
        "memory": "512Mi",
        "trigger": "manual_or_workflow"
      }
    },
    {
      "key": "workflow:daily-pipeline",
      "label": "Workflow",
      "properties": {
        "name": "daily-pipeline",
        "platform": "Cloud Workflows",
        "schedule": "5 0 * * *"
