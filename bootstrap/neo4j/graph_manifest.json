        "cpu": "1",
        "memory": "512Mi",
        "min_instances": 0,
        "max_instances": 1
      }
    },
    {
      "key": "job:dvb-annotator-job",
      "label": "CloudRunJob",
      "properties": {
        "name": "dvb-annotator-job",
        "runtime": "Python + Gemini API",
        "cpu": "1",
        "memory": "512Mi",
        "trigger": "manual_or_workflow"
      }
    },
    {
      "key": "job:dvb-extractor-job",
