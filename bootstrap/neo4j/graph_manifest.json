    {
      "key": "project:cpe-final-project",
      "label": "Project",
      "properties": {
        "name": "CPE Final Project",
        "project_id": "cpe-final-project",
        "provider": "gcp",
        "region": "asia-southeast1"
      }
    },
    {
      "key": "repo:cpe-final-project",
      "label": "Repository",
      "properties": {
        "name": "CPE_Final_Project",
        "path": "/home/akt/D/workspace/CPE_Final_Project",
        "vcs": "git"
      }
    },
    {
      "key": "workflow:terraform-deploy",
      "label": "CiWorkflow",
      "properties": {
        "name": "terraform-deploy",
