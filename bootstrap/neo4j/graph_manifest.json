      }
    },
    {
      "key": "bucket:crawler-data",
      "label": "StorageBucket",
      "properties": {
        "name": "crawler-data",
        "retention_days": 90,
        "purpose": "raw DVB articles"
      }
    },
    {
      "key": "bucket:cleaned-crawler-data",
      "label": "StorageBucket",
      "properties": {
        "name": "cleaned-crawler-data",
        "retention_days": 90,
        "purpose": "cleaned articles"
      }
    },
    {
      "key": "bucket:crisis-crawler-data",
      "label": "StorageBucket",
      "properties": {
        "name": "crisis-crawler-data",
        "retention_days": 180,
        "purpose": "pending, crisis, and annotated articles"
      }
    },
    {
      "key": "bucket:llm-extraction",
      "label": "StorageBucket",
      "properties": {
        "name": "llm-extraction",
        "retention_days": -1,
        "purpose": "structured extracted crisis events"
      }
    },
    {
      "key": "bucket:gpu-job-outputs",
      "label": "StorageBucket",
      "properties": {
        "name": "gpu-job-outputs",
        "retention_days": 30,
        "purpose": "GPU batch outputs"
      }
    },
    {
      "key": "bucket:mlflow-artifacts",
      "label": "StorageBucket",
      "properties": {
        "name": "mlflow-artifacts",
        "retention_days": 90,
        "purpose": "MLflow artifacts"
      }
    },
    {
      "key": "bucket:terraform-state",
      "label": "StorageBucket",
      "properties": {
        "name": "terraform-state",
        "retention_days": -1,
        "purpose": "Terraform remote state"
      }
    },
    {
      "key": "source:dvb-news",
