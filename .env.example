# Copy to .env and replace the placeholder values.

# Terraform variables
TF_VAR_project_id=your-gcp-project-id
TF_VAR_region=us-central1
TF_VAR_zone=us-central1-a
TF_VAR_environment=dev

# Sensitive Terraform variables
TF_VAR_hf_token=replace-with-huggingface-token
TF_VAR_gemini_api_key=replace-with-gemini-api-key
