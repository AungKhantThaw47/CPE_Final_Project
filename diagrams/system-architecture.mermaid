graph TD
    subgraph Developer["Developer / CI-CD"]
        GH["GitHub Repository"]
        GHA[".github/workflows<br>terraform-deploy.yml"]
        POST["terraform_post_action.py<br>post-apply summary + graph sync"]
    end

    subgraph GCP["Google Cloud Platform (asia-southeast1)"]

        subgraph Registry["Artifact Registry"]
            AR["Docker Repository<br>cpe-docker-repo"]
        end

        subgraph Schedulers["Cloud Scheduler (Cron)"]
            SCHED1["daily-data-processor<br>0 * * * * (every hour)"]
        end

        subgraph Jobs["Cloud Run Jobs (On-Demand / Scheduled)"]
            J1["dvb-crawler-job<br>1 CPU · 512 MB<br>Node.js"]
            J2["dvb-text-cleaner-job<br>1 CPU · 512 MB<br>Python"]
            J3["crisis-classifier-job<br>4 CPU · 16 GB<br>Python + HF"]
            J4["gpu-batch-job<br>4 CPU · 16 GB · L4 GPU<br>Python + PyTorch"]
            J5["daily-data-processor<br>1 CPU · 512 MB<br>Python"]
        end

        subgraph Services["Cloud Run Services (Always-On HTTP)"]
            S1["mlflow<br>2 CPU · 4 GB<br>0-2 instances"]
            S2["crisis-admin<br>1 CPU · 512 MB<br>0-1 instances"]
            S3["dvb-annotator<br>1 CPU · 512 MB<br>0-3 instances"]
            S4["dvb-extractor<br>1 CPU · 512 MB<br>0-3 instances"]
        end

        subgraph Storage["Cloud Storage Buckets"]
            B1["crawler-data<br>90-day retention"]
            B2["cleaned-crawler-data<br>90-day retention"]
            B3["crisis-crawler-data<br>180-day retention"]
            B4["llm-extraction<br>(long-term)"]
            B5["gpu-job-outputs<br>30-day retention"]
            B6["mlflow-artifacts<br>90-day retention"]
            B7["terraform-state<br>(indefinite)"]
        end

        subgraph Events["Admin-driven transitions and optional Eventarc Triggers"]
            EA1["Admin job trigger<br>crisis_articles/ to annotator"]
            EA2["Admin job trigger<br>annotated_articles/ to extractor"]
        end

        IAM["IAM Service Accounts<br>(per job/service)"]
        CB["Cloud Build<br>(Docker image builds)"]
    end

    subgraph Graph["External Graph Database"]
        NEO["Neo4j<br>system dependency graph"]
        HASH["DeploymentHash nodes<br>content hash + updater"]
    end

    GH --> GHA
    GHA --> CB
    GHA --> POST
    CB --> AR
    AR --> J1 & J2 & J3 & J4 & J5
    AR --> S1 & S2 & S3 & S4

    SCHED1 -->|triggers| J5

    J1 -->|writes raw articles| B1
    J2 -->|reads raw, writes cleaned| B2
    J3 -->|reads cleaned, writes crisis| B3
    J4 -->|writes results| B5

    B3 -->|admin move to crisis_articles/| EA1
    EA1 -->|invokes dvb-annotator-job| S3
    S3 -->|writes annotated| B3

    B3 -->|admin move to annotated_articles/| EA2
    EA2 -->|invokes dvb-extractor-job| S4
    S4 -->|writes extracted| B4

    S2 -->|reads crisis articles| B3
    S1 -->|stores artifacts| B6

    IAM -.->|grants roles| J1 & J2 & J3 & J4 & J5
    IAM -.->|grants roles| S1 & S2 & S3 & S4

    J1 -.->|content hash node| HASH
    J2 -.->|content hash node| HASH
    J3 -.->|content hash node| HASH
    J4 -.->|content hash node| HASH
    J5 -.->|content hash node| HASH
    S1 -.->|content hash node| HASH
    S2 -.->|content hash node| HASH
    S3 -.->|content hash node| HASH
    S4 -.->|content hash node| HASH
    POST -->|updates generated graph| NEO
    HASH --> NEO
